// PlopKit API schema — User → Site → Widget → CommentWidget → Comment
// Auth models (User–Verification): better-auth shape; see api/src/lib/auth.ts before changing.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// --- Enums ---

enum WidgetType {
  comments
}

enum CommentStatus {
  pending
  approved
}

enum Plan {
  free
  hobby
  pro
}


// --- Auth (better-auth) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  plan          Plan @default(free)
  sessions      Session[]
  accounts      Account[]
  sites         Site[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

// OAuth state and other short-lived tokens; not referenced by PlopKit routes.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


// --- Sites & widgets ---

model Site {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  siteKey   String   @unique
  verified  Boolean  @default(false)
  widgets   Widget[]
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Widget {
  id            String         @id @default(cuid())
  type          WidgetType
  name          String
  widgetKey     String         @unique
  siteId        String
  site          Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  commentWidget CommentWidget?
  monthlyLoads  Int            @default(0)
  createdAt     DateTime       @default(now())
}


// --- Comments ---

model CommentWidget {
  id                    String    @id @default(cuid())
  widgetId              String    @unique
  widget                Widget    @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  autoApprove           Boolean   @default(false)
  comments              Comment[]
  createdAt             DateTime  @default(now())
  bannedWords           String[]  @default([])
  autoDeleteBannedWords Boolean   @default(false)
  pinnedCommentId       String?   @unique
  pinnedComment         Comment?  @relation("PinnedComment", fields: [pinnedCommentId], references: [id], onDelete: SetNull)
}

model Comment {
  id              String        @id @default(cuid())
  commentWidgetId String
  commentWidget   CommentWidget @relation(fields: [commentWidgetId], references: [id])
  widgetKey       String        
  pageUrl         String
  body            String
  status          CommentStatus @default(pending)
  deletedAt       DateTime?
  deletedByParent Boolean       @default(false)
  createdAt       DateTime      @default(now())
  parentId        String?
  parent          Comment?      @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies         Comment[]     @relation("Replies")
  quotedId        String?
  quoted          Comment?      @relation("QuotedComment", fields: [quotedId], references: [id], onDelete: SetNull)
  quotedBy        Comment[]     @relation("QuotedComment")
  isOwnerReply    Boolean       @default(false)
  pinnedIn        CommentWidget? @relation("PinnedComment")
  authorName      String        @default("Anonymous")
}
